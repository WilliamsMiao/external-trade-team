# 外部贸易团队 - Dockerfile (生产级)
FROM node:20-alpine

WORKDIR /app

# 安装系统依赖
RUN apk add --no-cache \
    curl \
    git \
    python3 \
    make \
    g++

# 复制依赖定义
COPY package*.json ./

# 安装生产依赖
RUN npm ci --omit=dev --no-audit --no-fund

# 复制应用代码
COPY . .

# 创建必要的目录
RUN mkdir -p \
    workspace \
    logs \
    data/clients \
    data/orders \
    data/suppliers

# 暴露端口
EXPOSE 18789 3000

# 使用非 root 用户运行
RUN chown -R node:node /app
USER node

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:18789/health || exit 1

# 启动应用
CMD ["npm", "start"]
