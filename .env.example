# ===========================================
# 外部贸易团队 - 环境变量配置
# 复制此文件为 .env 后填入真实值
# ===========================================

# ---- 数据库 ----
DB_PASSWORD=change_me_secure_password
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me_pgadmin_password

# ---- MiniMax LLM ----
MINIMAX_API_KEY=sk-your-minimax-key
MINIMAX_API_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL_GENERAL=minimax-m2.1
MINIMAX_MODEL_HIGHSPEED=minimax-m2.5-highspeed
MINIMAX_MODEL_REASONING=minimax-reasoning

# ---- 邮件 SMTP ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourbusiness.com
AUDIT_EMAIL=audit@yourbusiness.com

# ---- CRM ----
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_CLIENT_ID=your_client_id
SALESFORCE_CLIENT_SECRET=your_secret
SALESFORCE_USERNAME=your_username
SALESFORCE_PASSWORD=your_password
HUBSPOT_API_KEY=pat-your-hubspot-key

# ---- 支付 ----
STRIPE_API_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
WISE_API_TOKEN=your_wise_api_token

# ---- 物流 ----
FEDEX_API_KEY=your_fedex_key
FEDEX_ACCOUNT_NUMBER=your_fedex_account
DHL_API_KEY=your_dhl_key

# ---- Telegram Bot (各职能) ----
TELEGRAM_BOT_TOKEN_COORDINATOR=change_me
TELEGRAM_BOT_TOKEN_HR=change_me
TELEGRAM_BOT_TOKEN_SALES_LEAD=change_me
TELEGRAM_BOT_TOKEN_SUPPLY_LEAD=change_me
TELEGRAM_BOT_TOKEN_OPS_LEAD=change_me
TELEGRAM_BOT_TOKEN_FINANCE_LEAD=change_me

# ---- Telegram 群组 ----
TELEGRAM_CHAT_ID_MGMT_HQ=change_me
TELEGRAM_CHAT_ID_SALES_TEAM=change_me
TELEGRAM_CHAT_ID_SUPPLY_TEAM=change_me
TELEGRAM_CHAT_ID_OPS_TEAM=change_me
TELEGRAM_CHAT_ID_FINANCE_TEAM=change_me

# ---- 系统 ----
NODE_ENV=production
LOG_LEVEL=info
TIMEZONE=Asia/Hong_Kong

# ---- 备份 ----
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
MONITORING_ENABLED=true
