# ===========================================
# 外部贸易团队 - 环境变量配置
# 复制此文件为 .env 后填入真实值
# ===========================================

# ---- 数据库 ----
DB_PASSWORD=change_me_secure_password
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me_pgadmin_password

# ---- MiniMax LLM ----
MINIMAX_API_KEY=sk-your-minimax-key
MINIMAX_API_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL_GENERAL=minimax-m2.1
MINIMAX_MODEL_HIGHSPEED=minimax-m2.5-highspeed
MINIMAX_MODEL_REASONING=minimax-reasoning

# ===========================================
# 选品数据源 API
# ===========================================

# 1688/阿里巴巴
ALIBABA_APP_KEY=your_app_key
ALIBABA_APP_SECRET=your_app_secret
ALIBABA_MEMBER_ID=your_member_id

# Amazon Product API
AMAZON_ACCESS_KEY=your_access_key
AMAZON_SECRET_KEY=your_secret_key
AMAZON_ASSOCIATE_TAG=your_tag
AMAZON_MARKETPLACE=com  # com/de/co.uk

# Google Trends (通过SerpAPI)
SERPAPI_KEY=your_serpapi_key
GOOGLE_TRENDS_KEY=your_google_key

# 速卖通
ALIEXPRESS_APP_KEY=your_app_key
ALIEXPRESS_APP_SECRET=your_secret

# 海关数据
CUSTOMS_API_KEY=your_customs_key

# ===========================================
# 获客数据源 API
# ===========================================

# 阿里巴巴国际站
ALIBABA_TRADE_APP_KEY=your_trade_app_key
ALIBABA_TRADE_APP_SECRET=your_trade_secret

# WhatsApp Business
WHATSAPP_BUSINESS_ID=your_business_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# LinkedIn
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret

# Google Ads
GOOGLE_ADS_CLIENT_ID=your_client_id
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token

# 独立站/表单
FORMSPREE_KEY=your_formspree_key
TYPEFORM_API_KEY=your_typeform_key

# ===========================================
# CRM 集成
# ===========================================

# HubSpot
HUBSPOT_API_KEY=pat-your-hubspot-key

# Salesforce
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_CLIENT_ID=your_client_id
SALESFORCE_CLIENT_SECRET=your_client_secret
SALESFORCE_USERNAME=your_username
SALESFORCE_PASSWORD=your_password

# ===========================================
# 支付 (未来扩展)
# ===========================================

STRIPE_API_KEY=sk_live_your_key
WISE_API_TOKEN=your_wise_token

# ===========================================
# 物流 (未来扩展)
# ===========================================

FEDEX_API_KEY=your_fedex_key
FEDEX_ACCOUNT_NUMBER=your_fedex_account
DHL_API_KEY=your_dhl_key

# ===========================================
# Telegram Bot
# ===========================================

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID_MGMT_HQ=change_me
TELEGRAM_CHAT_ID_SALES_TEAM=change_me

# ===========================================
# 系统
# ===========================================

NODE_ENV=production
LOG_LEVEL=info
TIMEZONE=Asia/Hong_Kong

# ---- 备份 ----
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
